---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  agendaData,
  buildDayJsonLd,
  formatDateLong,
  formatDateShort,
  getAvailableDates,
  getItemsByDate,
} from "../../lib/agenda";

export function getStaticPaths() {
  return getAvailableDates().map((fecha) => ({ params: { fecha } }));
}

const fecha = Astro.params.fecha || "";
const dayItems = getItemsByDate(fecha);
const allDates = getAvailableDates();
const fullDate = formatDateLong(fecha);

const title = `FLIMM 2026 | Agenda del ${fullDate}`;
const description = `${dayItems.length} actividades oficiales de FLIMM para el ${fullDate} en San Jacinto, Montes de Maria.`;
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={`/agenda/${fecha}/`}
  jsonLd={buildDayJsonLd(fecha)}
>
  <main class="app" data-selected-date={fecha}>
    <header class="hero">
      <div class="hero__top">
        <img src="/logo.png" alt="Logo FLIMM" class="hero__logo" />
        <div class="hero__social" aria-label="Redes sociales de FLIMM">
          <a
            class="hero__social-link"
            href="https://www.instagram.com/flimontesdemaria/"
            target="_blank"
            rel="noreferrer"
            aria-label="Instagram de FLIMM"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7.75 3h8.5A4.75 4.75 0 0 1 21 7.75v8.5A4.75 4.75 0 0 1 16.25 21h-8.5A4.75 4.75 0 0 1 3 16.25v-8.5A4.75 4.75 0 0 1 7.75 3Zm0 1.5A3.25 3.25 0 0 0 4.5 7.75v8.5a3.25 3.25 0 0 0 3.25 3.25h8.5a3.25 3.25 0 0 0 3.25-3.25v-8.5a3.25 3.25 0 0 0-3.25-3.25Zm8.88 1.12a.88.88 0 1 1 0 1.76.88.88 0 0 1 0-1.76ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Z" fill="currentColor"></path>
            </svg>
          </a>
          <a
            class="hero__social-link"
            href="https://www.facebook.com/profile.php?id=61586510319509"
            target="_blank"
            rel="noreferrer"
            aria-label="Facebook de FLIMM"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M13.33 21v-7.73h2.6l.39-3.02h-2.99V8.33c0-.87.24-1.47 1.5-1.47H16.5V4.15c-.29-.04-1.29-.12-2.45-.12-2.43 0-4.1 1.48-4.1 4.21v2.01H7.2v3.02h2.75V21h3.38Z" fill="currentColor"></path>
            </svg>
          </a>
        </div>
      </div>
      <p class="hero__kicker">Programacion oficial</p>
      <h1>{agendaData.evento}</h1>
      <p id="hero-subtitle" class="hero__subtitle">{fullDate} - San Jacinto, Montes de Maria</p>
    </header>

    <section class="panel" aria-labelledby="agenda-title">
      <div class="panel__head">
        <h2 id="agenda-title">Agenda del dia</h2>
        <p id="agenda-meta" class="panel__meta">{fullDate} - {dayItems.length} actividades</p>
      </div>

      <div class="agenda-controls">
        <nav id="day-tabs" class="day-tabs" aria-label="Seleccionar dia">
          {allDates.map((date) => (
            <a class="day-tab" href={`/agenda/${date}/`} aria-current={date === fecha ? "page" : undefined}>
              {formatDateShort(date)}
            </a>
          ))}
        </nav>

        <section class="filters" aria-label="Filtros de agenda">
          <div class="filter" id="venue-filter">
            <button
              id="venue-filter-btn"
              class="filter__button"
              type="button"
              aria-expanded="false"
              aria-controls="venue-filter-menu"
            >
              Lugar: Todos
            </button>
            <div id="venue-filter-menu" class="filter__menu" hidden></div>
          </div>

          <div class="filter" id="type-filter">
            <button
              id="type-filter-btn"
              class="filter__button"
              type="button"
              aria-expanded="false"
              aria-controls="type-filter-menu"
            >
              Tipo: Todos
            </button>
            <div id="type-filter-menu" class="filter__menu" hidden></div>
          </div>
        </section>
      </div>

      <div class="agenda-search">
        <label class="agenda-search__label" for="search-input">Buscar por nombre o participantes</label>
        <input
          id="search-input"
          class="agenda-search__input"
          type="search"
          placeholder="Ej: Gaitas de San Jacinto"
          autocomplete="off"
        />
      </div>

      <div id="agenda" class="timeline" aria-live="polite">
        {dayItems.map((item) => (
          <article class="card" data-type={item.tipo || ""}>
            <button class="card__toggle" type="button" aria-expanded="false">
              <span class="card__time">{item.horario || "Hora por confirmar"}</span>
              <span class="card__content">
                <span class="card__type">{item.tipo || "ACTIVIDAD"}</span>
                <span class="card__title">{item.nombre || "Sin titulo"}</span>
                <span class="card__venue">{item.sede ? `📍 ${item.sede}` : "📍 Sede por confirmar"}</span>
              </span>
              <span class="card__icon" aria-hidden="true">+</span>
            </button>
            <div class="card__details" hidden>
              <p class="card__info">{item.info || "Sin detalle"}</p>
              <p class="card__participants">{item.participantes || "Por confirmar"}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <footer class="site-footer">
      <p>Construido por: <strong><a href="https://lsarmiento.dev?utm_source:flimm" target="_blank">Luis Sarmiento</a></strong>.</p>
    </footer>
  </main>

  <template id="activity-template">
    <article class="card">
      <button class="card__toggle" type="button" aria-expanded="false">
        <span class="card__time"></span>
        <span class="card__content">
          <span class="card__type"></span>
          <span class="card__title"></span>
          <span class="card__venue"></span>
        </span>
        <span class="card__icon" aria-hidden="true">+</span>
      </button>
      <div class="card__details" hidden>
        <p class="card__info"></p>
        <p class="card__participants"></p>
      </div>
    </article>
  </template>

  <script type="module" src="/scripts/agenda-filters.js"></script>
</BaseLayout>
